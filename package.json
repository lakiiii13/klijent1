{
  "name": "la-vie-salon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-port.js && concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:phone": "node scripts/kill-port.js && concurrently \"npm run dev:server\" \"vite --host\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "jsonwebtoken": "^9.0.2",
    "lenis": "^1.1.18",
    "nodemailer": "^6.9.16",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
